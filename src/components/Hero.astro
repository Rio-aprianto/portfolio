---

---

<section id='home' class='pt-28 md:pt-32 pb-16 md:pb-24 px-5 lg:px-8'>
  <div class='max-w-6xl mx-auto grid md:grid-cols-2 gap-10 items-center'>
    <div class='reveal order-2 md:order-1'>
      <p class='text-amber-500 text-sm font-medium mb-3'>Hi There</p>
      <h1
        class='text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-brand leading-tight'
      >
        Rio<br />Aprianto
      </h1>
      <h2 class='mt-4 text-lg font-semibold text-slate-800'>
        Web &amp; Mobile Developer
      </h2>
      <p class='mt-4 text-slate-500 max-w-md leading-relaxed'>
        Saya membantu Anda membuat website dan aplikasi mobile yang elegan,
        ringan, dan tepat sasaran untuk bisnis maupun kebutuhan personal.
      </p>
      <div class='mt-7 flex flex-wrap gap-3'>
        <a
          href='#contact'
          class='inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white font-medium px-6 py-3 rounded-full shadow-lg shadow-brand/30 transition'
        >
          Hubungi Saya
          <svg
            width='16'
            height='16'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'><path d='M5 12h14M13 5l7 7-7 7'></path></svg
          >
        </a>
        <a
          href='#portfolio'
          class='inline-flex items-center gap-2 border border-slate-200 hover:border-brand hover:text-brand text-slate-700 font-medium px-6 py-3 rounded-full transition'
        >
          Lihat Portfolio
        </a>
      </div>
      <div class='mt-8 flex items-center gap-3'>
        {
          ["facebook", "instagram", "github", "linkedin"].map((s) => (
            <a
              href='#'
              aria-label={s}
              class='w-9 h-9 rounded-full bg-white shadow ring-1 ring-slate-100 grid place-items-center text-brand hover:bg-brand hover:text-white transition'>
              <svg
                width='14'
                height='14'
                viewBox='0 0 24 24'
                fill='currentColor'>
                <circle cx='12' cy='12' r='4' />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
    <div
      class='order-1 md:order-2 flex justify-center md:justify-end reveal reveal-delay-2'
    >
      <div class='relative w-[260px] h-[290px] sm:w-[340px] sm:h-[380px]'>
        <div class='absolute inset-0 bg-brand animate-blob'></div>
        <div class='absolute inset-0 grid place-items-end pb-2'>
          <img
            src='hero.png'
            alt='Rio Aprianto'
            class='w-40 sm:w-80 rounded-full shadow-lg shadow-brand/50'
          />
        </div>
      </div>
    </div>
  </div>
  <p class='text-center text-xs tracking-widest text-slate-400 mt-14 reveal'>
    SCROLL BAWAH UNTUK MELIHAT PORTFOLIO SAYA
  </p>
</section>
