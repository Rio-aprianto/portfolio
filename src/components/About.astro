---
const services = [
  {
    icon: "https://img.icons8.com/?size=100&id=102552&format=png&color=0EA5E9",
    title: "Website Development",
    desc: "Landing Page, Company Profile, Website Organisasi, hingga Sistem Informasi berbasis web dengan desain modern dan performa optimal.",
  },
  {
    icon: "https://img.icons8.com/?size=100&id=8XCtpwQjuerS&format=png&color=0EA5E9",
    title: "Mobile App",
    desc: "Pengembangan aplikasi Android yang ringan, cepat, responsif, dan nyaman digunakan dengan teknologi modern.",
  },
  {
    icon: "https://img.icons8.com/?size=100&id=QanbId3SGVR7&format=png&color=0EA5E9",
    title: "Solusi Akademik",
    desc: "Membantu pembuatan aplikasi, UML, dokumentasi skripsi, sistem informasi, maupun kebutuhan akademik lainnya.",
  },
  {
    icon: "https://img.icons8.com/?size=100&id=13772&format=png&color=0EA5E9",
    title: "Undangan Digital",
    desc: "Undangan online yang elegan, modern, responsif, serta mudah dibagikan ke berbagai platform.",
  },
];

const strengths = [
  "Desain Modern & Profesional",
  "Pengerjaan Tepat Waktu",
  "Responsive di Semua Device",
  "Desain Bisa Request",
  "Konsultasi Gratis",
  "Revisi Sesuai Kesepakatan",
];
---

<section
  id="about"
  class="relative overflow-hidden py-24 px-5 lg:px-8 bg-slate-50"
>

  <!-- Background -->
  <div
    class="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-sky-300/20 blur-[120px]"
  ></div>

  <div
    class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-cyan-300/20 blur-[120px]"
  ></div>

  <div class="relative max-w-6xl mx-auto">

    <!-- Heading -->

    <div class="max-w-3xl reveal">

      <p
        class="text-brand uppercase tracking-[0.3em] font-semibold text-sm"
      >
        ABOUT ME
      </p>

      <h2
        class="mt-3 text-4xl md:text-5xl font-extrabold text-slate-900 leading-tight"
      >
        Membangun Solusi Digital
        <span class="text-brand">Modern & Berkualitas</span>
      </h2>

      <p class="mt-6 text-lg leading-8 text-slate-600">

        Saya membantu
        <span class="font-semibold text-slate-900">UMKM</span>,
        <span class="font-semibold text-slate-900">Instansi</span>,
        <span class="font-semibold text-slate-900">Mahasiswa</span>,
        hingga kebutuhan pribadi dalam membangun website,
        aplikasi mobile, sistem informasi, dan undangan digital
        yang modern, responsif, cepat, dan mudah digunakan.

      </p>

    </div>

    <!-- Services -->

    <div class="grid md:grid-cols-2 gap-7 mt-16">

      {
        services.map((item) => (

          <div
            class="group rounded-3xl bg-white/90 backdrop-blur-xl p-8 border border-slate-200 hover:border-sky-400 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300"
          >

            <!-- Icon -->

            <div
              class="w-16 h-16 rounded-2xl bg-sky-100 flex items-center justify-center transition-all duration-300 group-hover:bg-sky-200"
            >

              <img
                src={item.icon}
                alt={item.title}
                class="w-9 h-9 transition-all duration-300 group-hover:scale-110 group-hover:rotate-6"
              />

            </div>

            <h3
              class="mt-6 text-xl font-bold text-slate-900 group-hover:text-brand transition-colors"
            >
              {item.title}
            </h3>

            <p
              class="mt-3 text-slate-600 leading-7"
            >
              {item.desc}
            </p>

            <!-- Link -->

            <div
              class="mt-6 flex items-center font-semibold text-brand"
            >

              Pelajari lebih lanjut

              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 ml-2 transition-transform duration-300 group-hover:translate-x-2"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >

                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />

              </svg>

            </div>

          </div>

        ))
      }

    </div>

    <!-- Why Choose Me -->
    <div
      class="relative mt-20 overflow-hidden rounded-[32px] shadow-2xl reveal bg-fixed bg-cover bg-center"
      style="background-image:url('https://i.pinimg.com/736x/cf/d5/8e/cfd58ec52156c7161f46dd27edf9a7c9.jpg');"
    >

      <!-- Overlay -->
      <div class="absolute inset-0 bg-slate-900/80"></div>

      <!-- Gradient -->
      <div class="absolute inset-0 bg-gradient-to-r from-sky-900/40 via-slate-900/20 to-cyan-900/40"></div>

      <!-- Glow Effect -->
      <div class="absolute -left-32 -top-32 w-96 h-96 rounded-full bg-sky-500/20 blur-[120px]"></div>

      <div class="absolute -right-32 -bottom-32 w-96 h-96 rounded-full bg-cyan-400/20 blur-[120px]"></div>

      <!-- Content -->
      <div class="relative z-10 p-10 lg:p-14">

        <div class="w-20 h-1 rounded-full bg-cyan-400"></div>

        <p class="mt-6 uppercase tracking-[0.3em] text-sky-200 text-sm font-semibold">
          WHY CHOOSE ARIXON
        </p>

        <h3 class="mt-3 text-3xl md:text-4xl font-bold text-white">
          Mengapa Memilih Saya?
        </h3>

        <p class="mt-5 max-w-3xl text-slate-200 leading-8">
          Setiap project dikerjakan dengan mengutamakan kualitas desain,
          performa, dan pengalaman pengguna sehingga menghasilkan solusi
          digital yang profesional, cepat, responsif, dan mudah dikembangkan
          sesuai kebutuhan Anda.
        </p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-10">

          {
            strengths.map((item) => (

              <div
                class="group flex items-center gap-4 rounded-2xl
                bg-white/10 backdrop-blur-md
                border border-white/10
                px-5 py-4
                hover:bg-white/20
                hover:border-cyan-300/50
                hover:scale-[1.03]
                transition-all duration-300"
              >

                <!-- Heroicon Check -->

                <div
                  class="flex h-11 w-11 items-center justify-center rounded-full
                  bg-cyan-400/20
                  text-cyan-300
                  transition-all duration-300
                  group-hover:bg-cyan-400
                  group-hover:text-white
                  group-hover:rotate-12"
                >

                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                    class="w-6 h-6"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M4.5 12.75l6 6 9-13.5"
                    />
                  </svg>

                </div>

                <span class="text-white font-medium">
                  {item}
                </span>

              </div>

            ))
          }

        </div>

      </div>

    </div>

</section>