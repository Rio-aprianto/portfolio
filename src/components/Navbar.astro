---
const links = [
  { href: "#home", label: "Home" },
  { href: "#about", label: "About" },
  { href: "#skills", label: "Skills" },
  { href: "#services", label: "Services" },
  { href: "#portfolio", label: "Portfolio" },
  { href: "#contact", label: "Contact" },
];
---

<header
  id='mainHeader'
  class='fixed top-0 inset-x-0 z-[999] transition-all duration-300 bg-transparent text-slate-700'
>
  <nav
    class='max-w-6xl mx-auto px-5 lg:px-8 h-16 flex items-center justify-between relative'
  >
    <a href='#home' class='flex items-center gap-1'>
      <img src='/logo.png' alt='Logo' class='w-10 h-10' />
      <span
        id='logoText'
        class='text-brand font-bold text-lg tracking-tight transition-colors duration-300'
      >
        Arixon
      </span>
    </a>

    <ul
      id='navMenu'
      class='nav-menu-mobile mobile-bg-control md:flex absolute md:static top-16 left-0 w-full md:w-auto border-b md:border-0 flex-col md:flex-row md:items-center gap-1 md:gap-7 p-5 md:p-0 text-sm font-medium transition-all duration-300'
    >
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class='nav-item nav-link-custom block px-3 py-2 rounded transition duration-300'>
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      id='navToggle'
      aria-label='Toggle menu'
      class='nav-toggle-btn md:hidden p-2 focus:outline-none relative z-[1000] transition-colors duration-300'
    >
      <svg
        width='24'
        height='24'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2'
      >
        <path class='burger-line' d='M4 6h16M4 12h16M4 18h16'></path>
        <path class='x-line hidden' d='M18 6L6 18M6 6l12 12'></path>
      </svg>
    </button>
  </nav>
</header>

<style>
  /* Efek Animasi Underline Modern */
  .nav-link-custom {
    position: relative;
  }
  .nav-link-custom::after {
    content: "";
    position: absolute;
    width: 0;
    height: 2px;
    bottom: 0;
    left: 4px;
    background-color: #38bdf8;
    transition: width 0.3s ease;
  }

  .nav-link-custom:hover::after {
    width: 85%;
  }

  #mainHeader.scrolled-active .nav-link-custom::after {
    background-color: #ffffff;
  }

  /* TAMPILAN MOBILE & FIX BUG KONTRAST */
  @media (max-width: 767px) {
    .nav-menu-mobile {
      display: none;
    }
    .nav-menu-mobile.active {
      display: flex !important;
      position: absolute;
      top: 64px;
      left: 0;
      width: 100%;
      z-index: 999;
    }

    /* Kondisi KELAS AWAL (Saat di paling atas halaman) */
    .mobile-bg-control {
      background-color: #ffffff; /* Background dropdown putih saat di atas */
      border-color: #f1f5f9; /* Border abu-abu terang */
    }

    /* Kondisi KETIKA SCROLL (Dropdown ikut berubah menjadi biru) */
    #mainHeader.scrolled-active .mobile-bg-control {
      background-color: #0ea5e9; /* Mengikuti warna bg-sky-500 */
      border-color: #38bdf8; /* Border biru sedikit terang */
    }
  }
</style>

<script>
  function initNavbar() {
    const navToggle = document.getElementById("navToggle");
    const navMenu = document.getElementById("navMenu");
    const header = document.getElementById("mainHeader");
    const logoText = document.getElementById("logoText");
    const navItems = document.querySelectorAll(".nav-item");

    if (navToggle && navMenu) {
      navToggle.replaceWith(navToggle.cloneNode(true));
      const newToggle = document.getElementById("navToggle");
      const newBurger = document.querySelector(".burger-line");
      const newX = document.querySelector(".x-line");

      newToggle?.addEventListener("click", () => {
        navMenu.classList.toggle("active");
        newBurger?.classList.toggle("hidden");
        newX?.classList.toggle("hidden");
      });
    }

    function handleScroll() {
      if (!header) return;

      if (window.scrollY > 20) {
        // KONDISI SAAT SCROLL (Warna Biru)
        header.classList.remove("bg-transparent", "text-slate-700");
        header.classList.add(
          "bg-sky-500",
          "text-white",
          "shadow-lg",
          "scrolled-active",
        );

        logoText?.classList.remove("text-brand");
        logoText?.classList.add("text-white");

        navItems.forEach((item) => {
          item.classList.remove("text-slate-700");
          item.classList.add("text-white");
        });

        navToggle?.classList.remove("text-slate-700");
        navToggle?.classList.add("text-white");
      } else {
        // KONDISI DI ATAS (Transparan)
        header.classList.add("bg-transparent", "text-slate-700");
        header.classList.remove(
          "bg-sky-500",
          "text-white",
          "shadow-lg",
          "scrolled-active",
        );

        logoText?.classList.add("text-brand");
        logoText?.classList.remove("text-white");

        navItems.forEach((item) => {
          item.classList.add("text-slate-700");
          item.classList.remove("text-white");
        });

        navToggle?.classList.add("text-slate-700");
        navToggle?.classList.remove("text-white");
      }
    }

    window.addEventListener("scroll", handleScroll);
    handleScroll();
  }

  initNavbar();
  document.addEventListener("astro:page-load", initNavbar);
</script>
